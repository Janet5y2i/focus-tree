# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/focus-tree

# Auth — use a long random string in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Cookie name (optional override)
AUTH_COOKIE_NAME=focus-tree-session

# AI 回顧總結（選填）— 未設定時會自動退回本地生成的溫暖總結
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
